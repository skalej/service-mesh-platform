extend schema @link(url: "https://specs.apollo.dev/federation/v2.0", import: ["@key"])

# Carrier is a first-class entity owned by Shipping.
# Other services (e.g. Catalog) can extend it via @key.
type Carrier @key(fields: "id") {
    id: ID!
    name: String!
    estimatedDays: Int!
}

type ShippingInfo {
    carrier: Carrier!
}

type Product @key(fields: "id") {
    id: ID!
    shippingInfo: ShippingInfo!
}

type Query {
    shipping(productId: ID!): ShippingInfo
    carriers: [Carrier!]!
}
